<mvc:View
    controllerName="zattach.zattachfe.ext.main.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    displayBlock="true"
    height="100%">
    <Page
        id="Main"
        title="{i18n>AttachmentListTitle}"
        showNavButton="false">
        <content>
            <VBox id="_IDGenVBox3" class="sapUiSmallMargin">
                <!-- Filter Section -->
                <VBox id="_IDGenVBox4" class="sapUiSmallMarginBottom">
                    <Label id="_IDGenLabel3" text="Filter" class="sapUiTinyMarginBottom" design="Bold"/>
                    <HBox id="_IDGenHBox1" alignItems="Center" justifyContent="SpaceBetween">
                        <HBox id="_IDGenHBox2" alignItems="Center" class="sapUiTinyMarginEnd">
                            <Input
                                id="searchInput"
                                placeholder="{i18n>filterTitle}"
                                width="250px"
                                class="sapUiTinyMarginEnd"/>
                            <Input
                                id="versionInput"
                                placeholder="{i18n>filterVersion}"
                                width="200px"
                                class="sapUiTinyMarginEnd"/>
                            <Input
                                id="createdByInput"
                                placeholder="{i18n>filterCreatedBy}"
                                width="200px"
                                class="sapUiTinyMarginEnd"/>
                            <Button
                                id="goButton"
                                text="{i18n>btnGo}"
                                press="onFilterGo"
                                type="Emphasized"
                                width="100px"/>
                        </HBox>
                    </HBox>
                </VBox>

                <!-- Action Bar with New Button and View Toggle -->
                <Toolbar id="_IDGenToolbar1">
                    <Button
                        id="newButton"
                        text="{i18n>btnNew}"
                        icon="sap-icon://add"
                        press="onNewAttachment"
                        type="Emphasized"/>
                    <ToolbarSpacer id="_IDGenToolbarSpacer1"/>
                    <SegmentedButton
                        id="viewModeToggle"
                        selectedKey="{view>/viewMode}"
                        selectionChange="onViewModeChange">
                        <items>
                            <SegmentedButtonItem id="_IDGenSegmentedButtonItem"
                                key="list"
                                text="{i18n>viewList}"
                                icon="sap-icon://list"/>
                            <SegmentedButtonItem id="_IDGenSegmentedButtonItem1"
                                key="grid"
                                text="{i18n>viewGrid}"
                                icon="sap-icon://grid"/>
                        </items>
                    </SegmentedButton>
                </Toolbar>

                <!-- List View -->
                <Table
                    id="attachmentTable"
                    items="{/Attachments}"
                    visible="{= ${view>/viewMode} === 'list'}"
                    mode="MultiSelect"
                    class="sapUiSmallMarginTop">
                    <columns>
                        <Column id="_IDGenColumn" width="30%">
                            <Text id="_IDGenText" text="{i18n>colTitle}"/>
                        </Column>
                        <Column id="_IDGenColumn1" width="15%">
                            <Text id="_IDGenText1" text="{i18n>colVersion}"/>
                        </Column>
                        <Column id="_IDGenColumn2" width="10%">
                            <Text id="_IDGenText2" text="{i18n>colActive}"/>
                        </Column>
                        <Column id="_IDGenColumn3" width="15%">
                            <Text id="_IDGenText3" text="{i18n>colCreatedBy}"/>
                        </Column>
                        <Column id="_IDGenColumn4" width="15%">
                            <Text id="_IDGenText4" text="{i18n>colChangedBy}"/>
                        </Column>
                        <Column id="_IDGenColumn5" width="20%">
                            <Text id="_IDGenText6" text="{i18n>colChangedDate}"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem id="_IDGenColumnListItem" type="Navigation" press="onItemPress">
                            <cells>
                                <ObjectIdentifier id="_IDGenObjectIdentifier"
                                    title="{Title}"
                                    text="{FileId}"/>
                                <Text id="_IDGenText7" text="{CurrentVersion}"/>
                                <Text id="_IDGenText8" text="{path: 'IsActive', formatter: '.formatter.formatBoolean'}"/>
                                <Text id="_IDGenText9" text="{Ernam}"/>
                                <Text id="_IDGenText10" text="{Aenam}"/>
                                <Text id="_IDGenText11" text="{path: 'Aedat', formatter: '.formatter.formatDate'}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

                <!-- Grid View -->
                <ScrollContainer
                    id="attachmentGrid"
                    visible="{= ${view>/viewMode} === 'grid'}"
                    height="100%"
                    width="100%"
                    vertical="true"
                    class="sapUiSmallMarginTop">
                    <l:Grid id="_IDGenGrid"
                        defaultSpan="XL3 L4 M6 S12"
                        hSpacing="1"
                        vSpacing="1"
                        content="{/Attachments}">
                        <l:content>
                            <VBox id="_IDGenVBox5"
                                class="sapUiSmallMargin sapUiContentPadding sapUiSmallPaddingBeginEnd"
                                width="100%">
                                <HBox id="_IDGenHBox3" alignItems="Center" class="sapUiTinyMarginBottom">
                                    <core:Icon id="_IDGenIcon" src="sap-icon://attachment" size="2rem" class="sapUiTinyMarginEnd" color="#0854a0"/>
                                    <VBox id="_IDGenVBox6" width="100%">
                                        <Link id="_IDGenLink"
                                            text="{Title}"
                                            press="onAttachmentPress"/>
                                        <Text id="_IDGenText12" text="{= 'Version ' + ${CurrentVersion}}"/>
                                    </VBox>
                                </HBox>
                                <VBox id="_IDGenVBox7" class="sapUiTinyMarginTop">
                                    <HBox id="_IDGenHBox4" class="sapUiTinyMarginBottom">
                                        <Label id="_IDGenLabel4" text="{i18n>labelStatus}" class="sapUiTinyMarginEnd"/>
                                        <Text id="_IDGenText13" text="{path: 'IsActive', formatter: '.formatter.formatBoolean'}"/>
                                    </HBox>
                                    <HBox id="_IDGenHBox5" class="sapUiTinyMarginBottom">
                                        <Label id="_IDGenLabel5" text="{i18n>labelVersion}" class="sapUiTinyMarginEnd"/>
                                        <Text id="_IDGenText14" text="{CurrentVersion}"/>
                                    </HBox>
                                    <HBox id="_IDGenHBox6" class="sapUiTinyMarginBottom">
                                        <Label id="_IDGenLabel6" text="{i18n>labelCreatedBy}" class="sapUiTinyMarginEnd"/>
                                        <Text id="_IDGenText15" text="{Ernam}"/>
                                    </HBox>
                                    <HBox id="_IDGenHBox7">
                                        <Label id="_IDGenLabel7" text="{i18n>labelChangedBy}" class="sapUiTinyMarginEnd"/>
                                        <Text id="_IDGenText16" text="{Aenam}"/>
                                    </HBox>
                                    <HBox id="attachmentChangedDateRow" class="sapUiTinyMarginTop">
                                        <Label id="attachmentChangedDateLabel" text="{i18n>labelChangedDate}" class="sapUiTinyMarginEnd"/>
                                        <Text id="attachmentChangedDateText" text="{path: 'Aedat', formatter: '.formatter.formatDate'}"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </l:content>
                    </l:Grid>
                </ScrollContainer>
            </VBox>
        </content>
    </Page>
</mvc:View>
