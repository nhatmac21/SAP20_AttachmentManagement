<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.ui.unified">
    <Dialog
        id="attachmentDetailUploadVersionDialog"
        title="Upload New Version"
        contentWidth="52rem"
        busy="{versionUpload>/busy}">
        <content>
            <VBox id="uploadVersionRoot" class="sapUiSmallMargin">
                <Text id="attachmentDetailUploadVersionCurrentTitle" text="{= 'Current title: ' + ${view>/Title}}" class="sapUiSmallMarginBottom" />
                <Text id="attachmentDetailUploadVersionCurrentVersion" text="{= 'Current version: ' + ${view>/CurrentVersion}}" class="sapUiSmallMarginBottom" />
                <Text id="attachmentDetailUploadVersionCurrentFileId" text="{= 'File ID: ' + ${view>/FileId}}" class="sapUiSmallMarginBottom" />

                <Title id="attachmentDetailUploadVersionStep1Title" text="Step 1: Upload New File" level="H5" class="sapUiSmallMarginTop sapUiSmallMarginBottom" />

                <VBox id="attachmentDetailVersionDropZoneContainer" class="dropZoneContainer">
                    <core:HTML
                        id="attachmentDetailVersionDropZoneHtml"
                        content="
                            &lt;div id='versionDropZone' class='dropZone'&gt;
                                &lt;div class='dropZoneIcon'&gt;&#128193;&lt;/div&gt;
                                &lt;div class='dropZoneText'&gt;Drag and drop your file here&lt;/div&gt;
                                &lt;div class='dropZoneSubText'&gt;or click to browse&lt;/div&gt;
                                &lt;div class='dropZoneSubText' style='margin-top:0.5rem;color:#999;'&gt;Maximum file size: 10MB&lt;/div&gt;
                            &lt;/div&gt;
                        "
                        afterRendering="onVersionDropZoneRendered" />

                    <u:FileUploader
                        id="attachmentDetailVersionFileUploader"
                        name="versionFile"
                        uploadUrl=""
                        uploadOnChange="false"
                        change="onVersionFileChange"
                        visible="false" />

                    <VBox id="attachmentDetailVersionFilePreviewBox" visible="false">
                        <Panel id="attachmentDetailVersionFileInfoPanel" headerText="Selected File Information" expandable="false" class="sapUiSmallMarginTop">
                            <content>
                                <f:SimpleForm id="attachmentDetailVersionFileInfoForm" editable="false" layout="ResponsiveGridLayout">
                                    <f:content>
                                        <Label id="attachmentDetailVersionFileNameLabel" text="File Name" />
                                        <Text id="attachmentDetailVersionFileNameText" text="{versionUpload>/FileName}" />

                                        <Label id="attachmentDetailVersionFileExtensionLabel" text="File Extension" />
                                        <Text id="attachmentDetailVersionFileExtensionText" text="{versionUpload>/FileExtension}" />

                                        <Label id="attachmentDetailVersionMimeTypeLabel" text="MIME Type" />
                                        <Text id="attachmentDetailVersionMimeTypeText" text="{versionUpload>/MimeType}" />

                                        <Label id="attachmentDetailVersionFileSizeLabel" text="File Size" />
                                        <Text id="attachmentDetailVersionFileSizeText" text="{= ${versionUpload>/FileSize} + ' B'}" />
                                    </f:content>
                                </f:SimpleForm>
                            </content>
                        </Panel>

                        <core:HTML
                            id="attachmentDetailVersionFilePreviewHtml"
                            content="
                                &lt;div class='filePreviewContainer'&gt;
                                    &lt;div class='filePreviewHeader'&gt;
                                        &lt;div style='display:flex;align-items:center;flex:1;'&gt;
                                            &lt;div class='filePreviewIcon'&gt;&#128196;&lt;/div&gt;
                                            &lt;div class='filePreviewInfo'&gt;
                                                &lt;div class='filePreviewName' id='versionPreviewFileName'&gt;&lt;/div&gt;
                                                &lt;div class='filePreviewDetails' id='versionPreviewFileDetails'&gt;&lt;/div&gt;
                                            &lt;/div&gt;
                                        &lt;/div&gt;
                                    &lt;/div&gt;
                                &lt;/div&gt;
                            "
                            afterRendering="onVersionFilePreviewRendered" />

                        <HBox id="attachmentDetailVersionRemoveFileBox" justifyContent="End" class="sapUiSmallMarginTop">
                            <Button
                                id="attachmentDetailVersionRemoveFileButton"
                                text="Remove File"
                                icon="sap-icon://decline"
                                type="Reject"
                                press="onVersionRemoveFile" />
                        </HBox>
                    </VBox>
                </VBox>

                <Panel
                    id="attachmentDetailVersionContentPreviewBox"
                    headerText="File Preview"
                    expandable="true"
                    expanded="false"
                    visible="false"
                    class="sapUiSmallMarginTop">
                    <content>
                        <VBox id="attachmentDetailVersionContentPreviewContainer" alignItems="Center" class="sapUiSmallMargin">
                            <core:HTML id="attachmentDetailVersionImagePreview" visible="false" />
                            <Text
                                id="attachmentDetailVersionNoPreviewText"
                                text="Preview not available for this file type"
                                visible="false" />
                        </VBox>
                    </content>
                </Panel>
            </VBox>
        </content>
        <beginButton>
            <Button
                id="attachmentDetailUploadVersionConfirmButton"
                text="Upload"
                type="Emphasized"
                enabled="{= !${versionUpload>/busy}}"
                press="onUploadVersionConfirm" />
        </beginButton>
        <endButton>
            <Button
                id="attachmentDetailUploadVersionCancelButton"
                text="Cancel"
                enabled="{= !${versionUpload>/busy}}"
                press="onVersionUploadDialogCancel" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
