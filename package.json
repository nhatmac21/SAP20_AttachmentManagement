{
  "name": "zattachfe",
  "version": "0.0.1",
  "description": "SAP Fiori Application for Attachment Management",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "ui5 serve --config ui5.yaml --open test/flpSandbox.html",
    "start-local": "ui5 serve --config ui5-local.yaml --open test/flpSandbox.html",
    "serve": "ui5 serve --config ui5.yaml --open index.html",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "deploy": "fiori verify",
    "deploy-config": "fiori add deploy-config",
    "start-noflp": "ui5 serve --config ui5-local.yaml --open index.html",
    "start-variants-management": "fiori run --open \"preview.html?sap-ui-xx-viewCache=false&fiori-tools-rta-mode=true&sap-ui-rta-skip-flex-validation=true#preview-app\"",
    "unit-tests": "fiori run --open 'test/unit/unitTests.qunit.html'",
    "int-tests": "fiori run --open 'test/integration/opaTests.qunit.html'",
    "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo"
  },
  "devDependencies": {
    "@sap/ux-specification": "^1.120.0",
    "@sap/ui5-builder-webide-extension": "^1.1.9",
    "@ui5/cli": "^4.0.49",
    "@sap/ux-ui5-tooling": "^1.14.4",
    "ui5-task-flatten-library": "^3.0.2"
  },
  "ui5": {
    "dependencies": [
      "@sap/ux-ui5-tooling",
      "@ui5/cli",
      "ui5-task-flatten-library"
    ]
  },
  "sapuxLayer": "CUSTOMER_BASE"
}
